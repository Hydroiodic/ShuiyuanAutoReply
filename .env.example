# OpenRouter API configuration
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview
OPENROUTER_MENTION_MODEL=
OPENROUTER_TAROT_MODEL=
OPENROUTER_TAROT_GROUP_MODEL=

# Primary Postgres database for quote records and, by default, LangMem memory.
POSTGRES_DB_URL=postgresql://shuiyuan:password@localhost:5432/shuiyuan
POSTGRES_STRICT=false
# Optional override if record tables should use a different Postgres database.
POSTGRES_RECORD_DB_URL=
POSTGRES_RECORD_STRICT=false
# Optional override if LangMem memory should use a different Postgres database.
POSTGRES_MEMORY_DB_URL=
POSTGRES_MEMORY_STRICT=false

# Neo4j database configuration
NEO4J_DB_URL=bolt://localhost:7687
NEO4J_DB_AUTH=("neo4j", "password")
NEO4J_STRICT=false

# Number of long-term memory items injected before model calls.
LANGMEM_SEARCH_LIMIT=5
# Max characters of formatted long-term memory context injected into the prompt.
LANGMEM_CONTEXT_MAX_CHARS=1600

# The embedding model to use for vectorizing text.
EMBEDDING_MODEL_NAME=moka-ai/m3e-base
EMBEDDING_DIMS=768

# Some additional configurations.
MCP_SERVER_URL=
HF_ENDPOINT=
OPENROUTER_PROXY=
